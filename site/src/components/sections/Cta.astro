---
const base = import.meta.env.BASE_URL;
---
<section class="section cta">
  <div class="container cta-inner reveal">
    <h2 class="display">Hand your agents <span class="grad-text">a world</span>.</h2>
    <p class="lede">Build the engine, run a demo, then connect an agent over MCP — or spawn one that lives inside the world.</p>
    <div class="cta-btns">
      <a class="btn btn-primary" href={`${base}getting-started`}>Get started</a>
      <a class="btn btn-ghost" href="https://github.com/syndicalt/limina" target="_blank" rel="noopener">View on GitHub</a>
    </div>
  </div>
</section>

<style>
  .cta { text-align: center; position: relative; }
  .cta::before {
    content: '';
    position: absolute; inset: 0; z-index: -1;
    background: radial-gradient(60% 80% at 50% 50%, rgba(47, 230, 214, 0.1), transparent 70%);
  }
  .cta-inner { max-width: 720px; margin-inline: auto; display: flex; flex-direction: column; align-items: center; }
  .cta .display { font-size: clamp(2.2rem, 5vw, 3.6rem); }
  .cta .lede { margin: 18px auto 0; }
  .cta-btns { display: flex; gap: 14px; margin-top: 30px; flex-wrap: wrap; justify-content: center; }
</style>
