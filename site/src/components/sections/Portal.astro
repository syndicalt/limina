---
// Black-hole portal, modelled on a real accretion disc (event-horizon shadow +
// photon ring + lensed disc over the top, Doppler-beamed, temperature-graded).
// It forms from a seed, spins up + grows + brightens as you scroll, the core
// blooms INTO a centered flash, then a fixed veil fades to the next section.
// Every layer is absolutely centered so nothing drifts off-axis.
interface Props { to?: string }
const { to } = Astro.props;
---
<section class="bh" data-portal aria-hidden="true">
  <div class="bh-stage">
    <div class="bh-glow"></div>
    <div class="bh-streaks"></div>
    <div class="bh-sys">
      <div class="bh-shadow"></div>
      <div class="bh-photon"></div>
    </div>
    <div class="bh-bloom"></div>
    {to && <span class="bh-label">Entering &middot; <b>{to}</b></span>}
  </div>
  <div class="bh-veil"></div>
  <div class="bh-flash"></div>
</section>

<style>
  .bh { position: relative; height: 200vh; }
  .bh-stage {
    position: sticky; top: 0; height: 100vh;
    overflow: hidden; perspective: 1200px;
    opacity: var(--stage-o, 1);
  }
  /* every visual layer is anchored to the exact viewport centre */
  .bh-stage > * { position: absolute; left: 50%; top: 50%; }

  .bh-glow {
    width: 860px; height: 860px; max-width: 150vw; max-height: 150vw; border-radius: 50%;
    background: radial-gradient(closest-side, rgba(255,170,90,0.16), rgba(120,200,255,0.10) 52%, transparent 72%);
    filter: blur(12px);
    transform: translate(-50%, calc(-50% + var(--glow-y, 0px))) scale(var(--glow-s, 1));
  }
  .bh-streaks {
    width: 150vmax; height: 150vmax; border-radius: 50%;
    background: repeating-conic-gradient(from 0deg,
      transparent 0deg 2.6deg, rgba(255,210,150,0.45) 2.6deg 3.0deg, transparent 3.0deg 6.8deg);
    -webkit-mask: radial-gradient(closest-side, transparent 7%, #000 22%, #000 60%, transparent 78%);
            mask: radial-gradient(closest-side, transparent 7%, #000 22%, #000 60%, transparent 78%);
    opacity: var(--streak-o, 0);
    transform: translate(-50%, -50%) scale(var(--streak-s, 0.4)) rotate(var(--streak-r, 0deg));
    mix-blend-mode: screen;
  }

  .bh-sys {
    display: grid; place-items: center;
    transform: translate(-50%, -50%) scale(calc(var(--size, 0.2) * var(--zoom, 1)));
  }
  .bh-sys > * { grid-area: 1 / 1; }

  .bh-plane { transform: scaleY(var(--flat, 0.32)); filter: brightness(var(--disc-b, 1)) saturate(1.35); }
  .bh-spin { display: grid; place-items: center; transform: rotate(var(--spin, 0deg)); }
  .bh-spin > * { grid-area: 1 / 1; }

  .bh-disc {
    width: 560px; height: 560px; max-width: 92vw; max-height: 92vw; border-radius: 50%;
    background: conic-gradient(from 0deg,
      rgba(255,150,60,0.45) 0deg, rgba(210,80,30,0.22) 70deg, rgba(150,45,25,0.12) 120deg,
      rgba(255,205,130,0.7) 165deg, rgba(255,252,244,1) 198deg, rgba(205,235,255,0.95) 222deg,
      rgba(255,200,120,0.6) 280deg, rgba(255,150,60,0.45) 360deg);
    -webkit-mask: radial-gradient(closest-side, transparent 43%, #000 50%, #000 90%, transparent 99%);
            mask: radial-gradient(closest-side, transparent 43%, #000 50%, #000 90%, transparent 99%);
    opacity: var(--ignite, 0.2); animation: bh-spin 24s linear infinite;
  }
  .bh-hot {
    width: 560px; height: 560px; max-width: 92vw; max-height: 92vw; border-radius: 50%;
    background: conic-gradient(from 0deg,
      rgba(255,235,200,0.5) 0deg, rgba(255,180,90,0.3) 120deg, rgba(255,255,255,1) 198deg,
      rgba(220,245,255,0.9) 230deg, rgba(255,235,200,0.5) 360deg);
    -webkit-mask: radial-gradient(closest-side, transparent 44%, #000 49%, #000 60%, transparent 66%);
            mask: radial-gradient(closest-side, transparent 44%, #000 49%, #000 60%, transparent 66%);
    opacity: var(--ignite, 0.2); animation: bh-spin 17s linear infinite;
  }
  .bh-fil {
    width: 560px; height: 560px; max-width: 92vw; max-height: 92vw; border-radius: 50%;
    background: repeating-conic-gradient(from 0deg,
      transparent 0deg 5deg, rgba(255,220,170,0.5) 5deg 7deg, transparent 7deg 9deg,
      rgba(255,180,120,0.35) 9deg 12deg, transparent 12deg 17deg);
    -webkit-mask: radial-gradient(closest-side, transparent 46%, #000 54%, #000 86%, transparent 96%);
            mask: radial-gradient(closest-side, transparent 46%, #000 54%, #000 86%, transparent 96%);
    opacity: calc(var(--ignite, 0.2) * 0.55); mix-blend-mode: screen; animation: bh-spin 9s linear infinite reverse;
  }

  .bh-shadow {
    width: 188px; height: 188px; max-width: 32vw; max-height: 32vw; border-radius: 50%;
    background: radial-gradient(closest-side, #01010a 70%, rgba(2,3,12,0.5) 86%, transparent 100%);
  }
  .bh-photon {
    width: 208px; height: 208px; max-width: 35vw; max-height: 35vw; border-radius: 50%;
    background: conic-gradient(from 0deg,
      rgba(255,240,220,0.35) 0deg, rgba(255,235,210,0.2) 120deg, rgba(255,255,255,1) 198deg,
      rgba(225,245,255,0.95) 226deg, rgba(255,240,220,0.35) 360deg);
    -webkit-mask: radial-gradient(closest-side, transparent 84%, #000 90%, #000 96%, transparent 100%);
            mask: radial-gradient(closest-side, transparent 84%, #000 90%, #000 96%, transparent 100%);
    box-shadow: 0 0 26px 3px rgba(255,240,220,0.5); opacity: var(--ignite, 0.2);
  }
  .bh-lens {
    width: 246px; height: 246px; max-width: 41vw; max-height: 41vw; border-radius: 50%;
    background: radial-gradient(closest-side, transparent 78%, rgba(255,225,180,0.9) 85%, rgba(255,170,90,0.5) 91%, transparent 98%);
    transform: scaleY(0.92); opacity: var(--ignite, 0.2); filter: blur(0.4px);
  }

  /* core bloom: the event horizon ignites into light, growing into the flash */
  .bh-bloom {
    width: 240px; height: 240px; border-radius: 50%;
    background: radial-gradient(closest-side, rgba(255,252,245,0.98), rgba(255,220,160,0.6) 38%, rgba(255,180,110,0.15) 64%, transparent 78%);
    opacity: var(--bloom-o, 0);
    transform: translate(-50%, -50%) scale(var(--bloom-s, 0.2));
    mix-blend-mode: screen; pointer-events: none;
  }

  .bh-label {
    top: auto; bottom: 13vh; transform: translateX(-50%);
    font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.26em; text-transform: uppercase;
    color: var(--muted); opacity: var(--label-o, 1);
  }
  .bh-label b { color: var(--glow); font-weight: 500; }

  .bh-veil { position: fixed; inset: 0; background: #01010a; opacity: var(--veil-o, 0); pointer-events: none; z-index: 200; }
  .bh-flash {
    position: fixed; inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(255,250,242,0.98), rgba(255,214,150,0.5) 26%, transparent 62%);
    opacity: var(--flash-o, 0); pointer-events: none; z-index: 201; mix-blend-mode: screen;
  }

  @keyframes bh-spin { to { transform: rotate(360deg); } }

  @media (prefers-reduced-motion: reduce) {
    .bh { height: auto; }
    .bh-stage { height: 260px; }
    .bh-disc, .bh-hot, .bh-fil { animation: none; }
    .bh-streaks, .bh-veil, .bh-flash, .bh-bloom { display: none; }
    .bh-sys { transform: translate(-50%, -50%) scale(0.8); }
  }
</style>

<script>
  const portals = [...document.querySelectorAll<HTMLElement>('[data-portal]')];
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (portals.length && !reduce) {
    const clamp = (v: number, a = 0, b = 1) => Math.min(b, Math.max(a, v));
    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
    const ease = (t: number) => t * t * (3 - 2 * t);
    let ticking = false;

    function update() {
      ticking = false;
      const vh = window.innerHeight;
      for (const el of portals) {
        const r = el.getBoundingClientRect();
        const s = el.style;
        const run = r.height - vh;
        const p = clamp(run > 0 ? -r.top / run : 0);

        const grow = ease(clamp(p / 0.55));
        const fly = ease(clamp((p - 0.5) / 0.45));

        s.setProperty('--size', lerp(0.16, 1.0, grow).toFixed(3));
        s.setProperty('--zoom', lerp(1, 2.4, fly).toFixed(3));        // gentle — stays centred on screen
        s.setProperty('--flat', lerp(0.72, 0.3, grow).toFixed(3));
        s.setProperty('--spin', (p * p * 1400 + p * 200).toFixed(1) + 'deg');
        s.setProperty('--ignite', ease(clamp(p / 0.4)).toFixed(3));
        s.setProperty('--disc-b', lerp(0.7, 1.9, p).toFixed(3));
        s.setProperty('--glow-s', lerp(0.8, 1.6, ease(clamp(p / 0.6))).toFixed(3));
        s.setProperty('--glow-y', lerp(40, -60, p).toFixed(1) + 'px');
        s.setProperty('--label-o', clamp(1 - (p - 0.22) / 0.16).toFixed(3));
        s.setProperty('--streak-o', (ease(clamp((p - 0.45) / 0.32)) * (1 - ease(clamp((p - 0.9) / 0.1))) * 0.85).toFixed(3));
        s.setProperty('--streak-s', lerp(0.35, 2.6, fly).toFixed(3));
        s.setProperty('--streak-r', (p * p * 520).toFixed(1) + 'deg');

        // the core ignites and blooms outward as you scroll in (→ the flash)
        const bloom = ease(clamp((p - 0.62) / 0.36));
        s.setProperty('--bloom-o', (bloom * 0.95).toFixed(3));
        s.setProperty('--bloom-s', lerp(0.25, 6.0, bloom).toFixed(3));

        // veil + flash keyed to the section boundary so they line up with the
        // reveal; flash peaks where the bloom does, both at screen centre.
        const b = r.bottom;
        s.setProperty('--stage-o', clamp((b - 0.5 * vh) / (0.18 * vh)).toFixed(3));
        let veil = 0;
        if (b > 0.95 * vh) veil = 0;
        else if (b > 0.68 * vh) veil = (0.95 * vh - b) / (0.27 * vh);
        else if (b > 0.5 * vh) veil = 1;
        else if (b > 0.05 * vh) veil = (b - 0.05 * vh) / (0.45 * vh);
        else veil = 0;
        s.setProperty('--veil-o', clamp(veil).toFixed(3));
        s.setProperty('--flash-o', Math.max(0, 1 - Math.abs(b - 0.92 * vh) / (0.12 * vh)).toFixed(3));
      }
    }
    const onScroll = () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } };
    addEventListener('scroll', onScroll, { passive: true });
    addEventListener('resize', onScroll);
    update();
  }
</script>
