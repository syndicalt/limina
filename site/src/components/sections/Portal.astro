---
// Black-hole portal between sections. As you scroll through it, the accretion
// disc spins up and brightens, the event horizon opens, then the whole thing
// zooms and the void swallows the screen into the next world. Scroll-linked
// (sets --p 0..1 on the element); pure transform/opacity, GPU-friendly.
interface Props { to?: string }
const { to } = Astro.props;
---
<section class="bh" data-portal aria-hidden="true">
  <div class="bh-stage">
    <div class="bh-glow"></div>
    <div class="bh-inner">
      <div class="bh-tilt"><div class="bh-disc"></div></div>
      <div class="bh-lens"></div>
      <div class="bh-core"></div>
    </div>
    <div class="bh-void"></div>
    {to && <span class="bh-label">Entering &middot; <b>{to}</b></span>}
  </div>
</section>

<style>
  .bh { position: relative; height: 145vh; }
  .bh-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    display: grid;
    place-items: center;
    overflow: hidden;
    perspective: 900px;
  }
  .bh-stage > * { grid-area: 1 / 1; }

  .bh-glow {
    width: 780px; height: 780px; max-width: 150vw; max-height: 150vw;
    border-radius: 50%;
    background: radial-gradient(closest-side, rgba(120,230,255,0.18), rgba(139,107,255,0.10) 55%, transparent 72%);
    filter: blur(8px);
    transform: translateY(var(--glow-y, 0)) scale(var(--glow-s, 1));
  }

  .bh-inner {
    display: grid;
    place-items: center;
    transform: scale(var(--zoom, 1));
  }
  .bh-inner > * { grid-area: 1 / 1; }

  .bh-tilt { transform: rotateX(74deg) scale(var(--disc-s, 1)); transform-style: preserve-3d; }
  .bh-disc {
    width: 520px; height: 520px; max-width: 86vw; max-height: 86vw;
    border-radius: 50%;
    background: conic-gradient(from 0deg,
      rgba(120,230,255,0) 0deg,
      rgba(120,230,255,0.95) 38deg,
      rgba(139,107,255,0.9) 120deg,
      rgba(255,180,84,0.55) 196deg,
      rgba(120,230,255,0) 250deg,
      rgba(120,230,255,0.95) 330deg,
      rgba(120,230,255,0) 360deg);
    -webkit-mask: radial-gradient(closest-side, transparent 52%, #000 58%, #000 88%, transparent 94%);
            mask: radial-gradient(closest-side, transparent 52%, #000 58%, #000 88%, transparent 94%);
    filter: saturate(1.15);
    animation: bh-spin 16s linear infinite;
  }
  .bh-lens {
    width: 300px; height: 300px; max-width: 56vw; max-height: 56vw;
    border-radius: 50%;
    box-shadow: 0 0 0 2px rgba(190,245,255,0.75), 0 0 34px 5px rgba(120,230,255,0.5);
    transform: scale(var(--core-s, 0.8));
  }
  .bh-core {
    width: 300px; height: 300px; max-width: 56vw; max-height: 56vw;
    border-radius: 50%;
    background: radial-gradient(closest-side, #01020a 60%, rgba(120,230,255,0) 74%);
    box-shadow: inset 0 0 46px rgba(0,0,0,0.95), 0 0 50px 8px rgba(120,230,255,0.22);
    transform: scale(var(--core-s, 0.8));
  }

  .bh-void {
    width: 120vmax; height: 120vmax;
    border-radius: 50%;
    background: radial-gradient(closest-side, #01020a 56%, rgba(120,230,255,0.55) 62%, rgba(139,107,255,0.0) 70%);
    transform: scale(var(--void-s, 0));
    opacity: var(--void-o, 0);
    pointer-events: none;
  }

  .bh-label {
    align-self: end;
    margin-bottom: 13vh;
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--muted);
    opacity: var(--label-o, 1);
  }
  .bh-label b { color: var(--glow); font-weight: 500; }

  @keyframes bh-spin { to { transform: rotate(360deg); } }

  @media (prefers-reduced-motion: reduce) {
    .bh { height: auto; }
    .bh-stage { position: relative; height: 220px; }
    .bh-disc { animation: none; }
    .bh-void { display: none; }
  }
</style>

<script>
  const portals = [...document.querySelectorAll<HTMLElement>('[data-portal]')];
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (portals.length && !reduce) {
    const clamp = (v: number, a = 0, b = 1) => Math.min(b, Math.max(a, v));
    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
    const ease = (t: number) => t * t * (3 - 2 * t);
    let ticking = false;

    function update() {
      ticking = false;
      const vh = window.innerHeight;
      for (const el of portals) {
        const r = el.getBoundingClientRect();
        const run = r.height - vh;
        const p = clamp(run > 0 ? -r.top / run : 0);
        const s = el.style;
        s.setProperty('--p', p.toFixed(4));
        s.setProperty('--disc-s', lerp(0.6, 1.12, ease(clamp(p / 0.6))).toFixed(3));
        s.setProperty('--core-s', lerp(0.22, 1.0, ease(clamp((p - 0.12) / 0.5))).toFixed(3));
        s.setProperty('--glow-s', lerp(0.8, 1.3, ease(clamp(p / 0.7))).toFixed(3));
        s.setProperty('--glow-y', lerp(50, -130, p).toFixed(1) + 'px');
        s.setProperty('--label-o', clamp(1 - (p - 0.26) / 0.16).toFixed(3));
        const sw = ease(clamp((p - 0.6) / 0.36));
        s.setProperty('--void-s', lerp(0, 7, sw).toFixed(3));
        s.setProperty('--void-o', clamp((p - 0.62) / 0.28).toFixed(3));
        s.setProperty('--zoom', lerp(1, 1.8, sw).toFixed(3));
      }
    }
    const onScroll = () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } };
    addEventListener('scroll', onScroll, { passive: true });
    addEventListener('resize', onScroll);
    update();
  }
</script>
