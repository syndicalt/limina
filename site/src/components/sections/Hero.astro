---
const base = import.meta.env.BASE_URL;
const pills = ['Rust', 'V8', 'WebGPU', 'Three.js', 'Rapier', 'bitECS'];
---
<section class="hero">
  <canvas id="cine-canvas" class="cine-canvas" aria-hidden="true"></canvas>
  <img
    class="cine-poster"
    id="cine-poster"
    src={`${base}media/hero-cinematic-poster.jpg`}
    alt=""
    aria-hidden="true"
  />
  <div class="cine-scrim" aria-hidden="true"></div>

  <div class="container hero-copy">
    <p class="eyebrow reveal">Agent-native real-time 3D engine</p>
    <h1 class="display reveal">
      Agents build the world.<br /><span class="grad-text">Then they live in it.</span>
    </h1>
    <p class="lede reveal">
      Limina is a real-time 3D engine where LLM agents are first-class. External
      <strong>builders</strong> construct scenes over MCP; autonomous
      <strong>players</strong> perceive, decide, and act inside them — every action
      typed, permission-checked, and traced.
    </p>
    <div class="hero-cta reveal">
      <a class="btn btn-primary" href={`${base}getting-started`}>Get started</a>
      <a class="btn btn-ghost" href={`${base}agents`}>For agents →</a>
    </div>
    <div class="hero-install reveal" data-install>
      <div class="hi-os" role="tablist" aria-label="Operating system">
        <button type="button" class="hi-tab" data-os="unix" aria-selected="true">macOS / Linux</button>
        <button type="button" class="hi-tab" data-os="win" aria-selected="false">Windows</button>
      </div>
      <div class="hi-cmd">
        <span class="hi-dollar" aria-hidden="true">$</span>
        <code class="hi-code">curl -fsSL https://www.liminaengine.com/install.sh | bash</code>
        <button type="button" class="hi-copy" aria-label="Copy install command">Copy</button>
      </div>
    </div>
    <ul class="hero-pills reveal" aria-label="Built on">
      {pills.map((p) => <li class="pill"><span class="dot"></span>{p}</li>)}
    </ul>
  </div>

  <div class="cine-loader" id="cine-loader" aria-hidden="true"><div class="bar"></div></div>

  <div class="cine-brand" id="cine-brand" aria-hidden="true">
    <svg viewBox="0 0 40 40" fill="none" aria-hidden="true">
      <defs>
        <linearGradient id="hero-lm" x1="6" y1="6" x2="34" y2="34" gradientUnits="userSpaceOnUse">
          <stop stop-color="#2fe6d6" /><stop offset="1" stop-color="#8b6bff" />
        </linearGradient>
      </defs>
      <path d="M9 33V18a11 11 0 0 1 22 0v15" stroke="url(#hero-lm)" stroke-width="3.2" stroke-linecap="round" />
      <circle cx="20" cy="24" r="3.2" fill="url(#hero-lm)" />
    </svg>
    <span>Powered by <b>Limina Engine</b></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    /* pull the hero up under the (transparent, sticky) nav so the cinematic is
       full-bleed and the bar overlays it */
    margin-top: -66px;
    display: grid;
    place-items: center;
    padding-block: clamp(120px, 15vh, 190px) clamp(60px, 9vh, 110px);
    overflow: hidden;
  }
  .cine-canvas,
  .cine-poster {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    z-index: 0;
    display: block;
  }
  .cine-poster { transition: opacity 0.6s ease; }
  .cine-canvas.hidden { display: none; }
  .cine-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(115% 85% at 50% 40%, rgba(7, 9, 18, 0.28), rgba(7, 9, 18, 0.62) 55%, rgba(7, 9, 18, 0.9)),
      linear-gradient(180deg, rgba(7, 9, 18, 0.5) 0%, rgba(7, 9, 18, 0.18) 36%, rgba(7, 9, 18, 0.72) 100%);
  }

  .hero-copy {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero .display { margin: 18px 0 0; max-width: 17ch; text-shadow: 0 2px 30px rgba(7, 9, 18, 0.55); }
  .hero .eyebrow { text-shadow: 0 1px 12px rgba(7, 9, 18, 0.6); }
  .hero .lede { margin: 22px auto 0; max-width: 62ch; color: #d8dfee; text-shadow: 0 1px 18px rgba(7, 9, 18, 0.85); }
  .hero .lede strong { color: var(--ink); font-weight: 600; }
  .hero-cta { display: flex; gap: 14px; margin-top: 30px; flex-wrap: wrap; justify-content: center; }
  .hero-pills {
    list-style: none;
    padding: 0;
    margin: 30px 0 0;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .hero .pill {
    color: #d2dbec;
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(3px);
  }
  .hero .eyebrow { color: var(--teal); }

  .cine-loader {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    height: 2px;
    background: transparent;
    transition: opacity 0.5s ease;
  }
  .cine-loader .bar { height: 100%; width: 0; background: var(--grad); transition: width 0.2s ease; }
  .cine-loader.done { opacity: 0; }

  .cine-brand {
    position: absolute;
    right: 22px;
    bottom: 20px;
    z-index: 3;
    display: flex;
    gap: 9px;
    align-items: center;
    opacity: 0;
    color: #eef3ff;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.6);
    pointer-events: none;
  }
  .cine-brand svg { width: 26px; height: 26px; filter: drop-shadow(0 0 10px rgba(47, 230, 214, 0.5)); }
  .cine-brand b {
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  @media (max-width: 640px) {
    .cine-brand { right: 14px; bottom: 14px; font-size: 0.85rem; }
  }
</style>

<script>
  import { initHeroCinematic } from '../../scripts/hero-cinematic';

  const canvas = document.getElementById('cine-canvas') as HTMLCanvasElement | null;
  const poster = document.getElementById('cine-poster');
  const loader = document.getElementById('cine-loader');
  const bar = loader?.querySelector('.bar') as HTMLElement | null;
  const brand = document.getElementById('cine-brand');

  if (canvas) {
    initHeroCinematic({
      canvas,
      overlay: { brand },
      onProgress(frac) {
        if (bar) bar.style.width = Math.round(frac * 100) + '%';
      },
      onReady() {
        loader?.classList.add('done');
        if (poster) poster.style.opacity = '0';
      },
      onError() {
        canvas.classList.add('hidden');
        loader?.classList.add('done');
        // poster stays visible as the static fallback
      },
    });
  }
</script>

<style>
  .hero-install { display: flex; flex-direction: column; align-items: center; gap: 11px; margin-top: 26px; }
  .hi-os {
    display: inline-flex; gap: 4px; padding: 3px;
    border-radius: 999px; background: rgba(150, 180, 230, 0.08); border: 1px solid var(--line);
  }
  .hi-tab {
    font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.03em;
    padding: 5px 13px; border-radius: 999px; color: var(--muted);
    border: 0; background: transparent; cursor: pointer;
    transition: color 0.2s, background 0.2s;
  }
  .hi-tab[aria-selected='true'] { background: rgba(120, 230, 255, 0.15); color: var(--glow); }
  .hi-cmd {
    display: inline-flex; align-items: center; gap: 10px;
    max-width: min(92vw, 560px);
    padding: 10px 10px 10px 16px;
    border-radius: var(--radius-btn);
    background: rgba(7, 10, 20, 0.62); border: 1px solid var(--line);
    backdrop-filter: blur(8px);
    box-shadow: 0 0 30px -10px rgba(120, 230, 255, 0.3);
  }
  .hi-dollar { color: var(--glow); font-family: var(--mono); opacity: 0.8; }
  .hi-code {
    font-family: var(--mono); font-size: 0.85rem; color: #dce6fb;
    white-space: nowrap; overflow-x: auto; scrollbar-width: none;
  }
  .hi-code::-webkit-scrollbar { display: none; }
  .hi-copy {
    flex: none; font-family: var(--mono); font-size: 0.72rem; color: var(--ink);
    padding: 7px 13px; border-radius: 9px; border: 1px solid var(--line);
    background: rgba(120, 230, 255, 0.08); cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .hi-copy:hover { border-color: rgba(120, 230, 255, 0.5); }
  .hi-copy.copied { color: var(--glow); border-color: rgba(120, 230, 255, 0.5); }
  @media (max-width: 520px) { .hi-code { font-size: 0.76rem; } }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-install]');
  if (root) {
    const CMD: Record<string, string> = {
      unix: 'curl -fsSL https://www.liminaengine.com/install.sh | bash',
      win: 'irm https://www.liminaengine.com/install.ps1 | iex',
    };
    const code = root.querySelector<HTMLElement>('.hi-code')!;
    const copy = root.querySelector<HTMLButtonElement>('.hi-copy')!;
    const tabs = [...root.querySelectorAll<HTMLElement>('.hi-tab')];

    const detect = (): string => {
      const nav = navigator as unknown as { userAgentData?: { platform?: string } };
      const plat = nav.userAgentData?.platform || navigator.platform || '';
      const ua = navigator.userAgent || '';
      return /win/i.test(plat) || /Windows/i.test(ua) ? 'win' : 'unix';
    };

    let os = detect();
    const render = () => {
      code.textContent = CMD[os];
      tabs.forEach((t) => t.setAttribute('aria-selected', String(t.dataset.os === os)));
      copy.textContent = 'Copy';
      copy.classList.remove('copied');
    };
    tabs.forEach((t) => t.addEventListener('click', () => { os = t.dataset.os || 'unix'; render(); }));
    copy.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(CMD[os]);
        copy.textContent = 'Copied';
        copy.classList.add('copied');
      } catch { /* clipboard unavailable */ }
    });
    render();
  }
</script>
