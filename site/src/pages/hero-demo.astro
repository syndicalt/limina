---
// Dev-only harness for the hero cinematic. Visit /hero-demo (optionally
// ?cineSeek=7 to freeze at a timeline second). Not linked from nav; used for
// visual checkpoints + poster capture. Safe to keep as a dev route.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Limina — hero cinematic (dev)</title>
    <style>
      html,body { margin: 0; height: 100%; background: #070912; overflow: hidden; }
      #cine-canvas { position: fixed; inset: 0; width: 100%; height: 100%; display: block; }
      .loader { position: fixed; left: 0; right: 0; bottom: 0; height: 3px; }
      .loader .bar { height: 100%; width: 0; background: linear-gradient(90deg,#2fe6d6,#8b6bff,#ff5aa0); transition: width .2s; }
      .brand {
        position: fixed; right: 24px; bottom: 22px; opacity: 0;
        display: flex; gap: 9px; align-items: center; color: #e9eef9;
        font: 600 15px/1 system-ui, sans-serif; letter-spacing: -0.01em;
        text-shadow: 0 2px 14px rgba(0,0,0,.6);
      }
      .brand svg { width: 26px; height: 26px; filter: drop-shadow(0 0 10px rgba(47,230,214,.5)); }
      .brand b { background: linear-gradient(90deg,#2fe6d6,#8b6bff); -webkit-background-clip: text; background-clip: text; color: transparent; }
    </style>
  </head>
  <body>
    <canvas id="cine-canvas"></canvas>
    <div class="loader"><div class="bar" id="bar"></div></div>
    <div class="brand" id="brand">
      <svg viewBox="0 0 40 40" fill="none" aria-hidden="true">
        <defs><linearGradient id="lm" x1="6" y1="6" x2="34" y2="34" gradientUnits="userSpaceOnUse">
          <stop stop-color="#2fe6d6" /><stop offset="1" stop-color="#8b6bff" /></linearGradient></defs>
        <path d="M9 33V18a11 11 0 0 1 22 0v15" stroke="url(#lm)" stroke-width="3.2" stroke-linecap="round" />
        <circle cx="20" cy="24" r="3.2" fill="url(#lm)" />
      </svg>
      <span>Powered by <b>Limina Engine</b></span>
    </div>

    <script>
      import { initHeroCinematic } from '../scripts/hero-cinematic';
      const canvas = document.getElementById('cine-canvas') as HTMLCanvasElement;
      const bar = document.getElementById('bar');
      const brand = document.getElementById('brand');
      initHeroCinematic({
        canvas,
        overlay: { brand },
        onProgress(f) { if (bar) bar.style.width = Math.round(f * 100) + '%'; },
        onReady() { if (bar) bar.style.opacity = '0'; },
        onError() { document.body.style.background = '#300'; console.error('hero cinematic: no webgl / load error'); },
      });
    </script>
  </body>
</html>
