# --- Rust / native build artifacts ---
target/
**/*.rs.bk

# --- Node / web build artifacts ---
node_modules/
dist/
.astro/

# --- Secrets & machine-specific local config (never publish) ---
.env
.env.*
/.mcp.json
/zaxy-mcp.json
/AGENTS.md

